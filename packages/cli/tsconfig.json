{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@inkeep/open-knowledge-core": ["../core/src/index.ts"],
      "@inkeep/open-knowledge-core/*": ["../core/src/*"],
      "@inkeep/open-knowledge-server": ["../server/src/index.ts"],
      "@inkeep/open-knowledge-server/*": ["../server/src/*"]
    }
  },
  "include": ["src", "*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
